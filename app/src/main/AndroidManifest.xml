<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:name=".DuopolyApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:label="Duopoly"
        android:supportsRtl="true"
        android:theme="@style/Theme.Duopoly"
        tools:targetApi="31">
        
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="Duopoly"
            android:theme="@style/Theme.Duopoly">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Actividad del motor Godot (Usamos nuestra implementación concreta) -->
        <activity
            android:name=".DuopolyGodotActivity"
            android:configChanges="orientation|keyboardHidden|screenSize|smallestScreenSize|screenLayout|density|uiMode"
            android:exported="false"
            android:label="Duopoly Game View"
            android:launchMode="singleTask"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen"
            android:screenOrientation="sensorPortrait">
            <meta-data
                android:name="org.godotengine.godot.main_pack"
                android:value="Duopoly.pck" />
            <meta-data
                android:name="org.godotengine.plugin.v1.DuopolyBridge"
                android:value="com.duopoly.bridge.DuopolyBridge" />
        </activity>

    </application>

</manifest>
